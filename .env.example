# X (Twitter) API Keys
# developer.twitter.com で取得したキーをコピーして .env に保存してください

TWITTER_API_KEY=ここにAPI Keyを貼る
TWITTER_API_SECRET=ここにAPI Key Secretを貼る
TWITTER_ACCESS_TOKEN=ここにAccess Tokenを貼る
TWITTER_ACCESS_SECRET=ここにAccess Token Secretを貼る

# サイトURL（投稿文に使う）
GAME_SITE_URL=https://your-game-station.vercel.app
BBQ_SITE_URL=https://your-bbq-site.vercel.app
